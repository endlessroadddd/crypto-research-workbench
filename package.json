{
  "name": "crypto-research-workbench",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @research/api --filter @research/web dev",
