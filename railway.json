{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
"buildCommand": "pnpm --filter @research/api build && node scripts/fix-esm.mjs"
  },
  "deploy": {
    "startCommand": "cd apps/api/dist/apps/api/src && node index.js",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

