{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "install": [
        "npm install -g @binance/binance-cli",
        "pnpm install --frozen-lockfile"
      ],
      "build": ["pnpm build"],
      "run": "cd apps/api && node dist/index.js"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
