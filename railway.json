{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
"buildCommand": "pnpm -r build && cd apps/api && node build.mjs"
  },
  "deploy": {
    "startCommand": "cd apps/api/dist && node bundle.js",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

